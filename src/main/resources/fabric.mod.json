{
  "schemaVersion": 1,
  "id": "slothyhub",
  "version": "${version}",
  "name": "Slothy's Tree",
  "description": "A sloth-themed resource pack hub. Browse, apply, and build custom texture packs. Hang from Slothy's Tree.",
  "authors": ["Ilyslothys"],
  "contact": {
    "homepage": "https://github.com/IlySlothy/Slothy-s-Tree",
    "sources":  "https://github.com/IlySlothy/Slothy-s-Tree",
    "issues":   "https://github.com/IlySlothy/Slothy-s-Tree/issues"
  },
  "license": "MIT",
  "icon": "assets/slothyhub/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.slothyhub.SlothyHubMod"]
  },
  "mixins": ["slothyhub.mixins.json"],
  "depends": {
    "fabricloader": ">=0.14.0",
    "minecraft": ">=1.20",
    "java": ">=21",
    "fabric-api": "*"
  }
}
